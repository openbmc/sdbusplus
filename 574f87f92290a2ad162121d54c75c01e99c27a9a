      "writtenOn": "2026-05-11T09:21:53Z",
      "side": 1,
      "message": "replied_ is set before the reply is actually sent. If append() / method_return() throws, replied_ stays true and the destructor skips the auto-EIO fallback → caller times out.\nSuggest moving the assignment after method_return() succeeds, or wrap in try/catch like coroutine_method_instance::after_spawn.",
      "range": {
        "startLine": 357,
        "startChar": 8,
        "endLine": 357,
        "endChar": 24
      },
      "revId": "574f87f92290a2ad162121d54c75c01e99c27a9a",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
