From 22f783ad8c60d78bb0041b1660a6494ed646fbfd Mon Sep 17 00:00:00 2001
From: Akash A <mirrorghost007@gmail.com>
Date: Wed, 29 Apr 2026 21:11:45 +0530
Subject: [PATCH 3/3] fix: resolve build errors for clang-tidy enablement

Replace missing <flat_map> with <boost/container/flat_map.hpp>.
Replace missing <print> with <cstdio> and printf format strings.
Remove deprecated testing::Invoke() calls and unused using
declarations in test files.

These fixes allow the clang-tidy tool to run without unrelated
build failures when compiling test targets.

Tested: Verified all 18 async tests pass. clang-tidy reports
zero warnings on modified files. Build completes successfully
with ninja.

Signed-off-by: Akash A <mirrorghost007@gmail.com>
---
 test/gen/test_method_names.cpp   | 8 ++++----
 test/gen/test_property_names.cpp | 6 +++---
 test/gen/test_signal_names.cpp   | 8 ++++----
 test/message/append.cpp          | 2 +-
 test/message/flat_map_test.cpp   | 5 +++--
 test/message/read.cpp            | 3 +--
 6 files changed, 16 insertions(+), 16 deletions(-)

diff --git a/test/gen/test_method_names.cpp b/test/gen/test_method_names.cpp
index 06e573ab..f89240ec 100644
--- a/test/gen/test_method_names.cpp
+++ b/test/gen/test_method_names.cpp
@@ -1,6 +1,6 @@
 #include "server/TestWithMethod/common.hpp"
 
-#include <print>
+#include <cstdio>
 
 #include <gtest/gtest.h>
 
@@ -14,15 +14,15 @@ TEST(MethodNames, TestMethodNames)
 
     // The method name can be used as part of error logs.
 
-    std::println("error calling method {}\n", methodName);
+    printf("error calling method %s\n", methodName);
 
     // If the method is removed from the interface definition, it will cause a
     // build failure in applications still using that method. That can work
     // even if the application is not (yet) using PDI-generated bindings for
     // it's DBus interactions.
 
-    std::println(
-        "using method {} \n",
+    printf(
+        "using method %s \n",
         sdbusplus::common::server::TestWithMethod::update_value_t::name);
 
     EXPECT_EQ(sdbusplus::common::server::TestWithMethod::update_value_t::name,
diff --git a/test/gen/test_property_names.cpp b/test/gen/test_property_names.cpp
